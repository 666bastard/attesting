# ============================================================
# Attesting — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# .env is gitignored — your secrets never leave this machine.
# ============================================================

# ── Server ───────────────────────────────────────────────────
# Port for the web UI and API server
ATTESTING_PORT=3000

# Bind address (0.0.0.0 for all interfaces, 127.0.0.1 for local only)
ATTESTING_HOST=0.0.0.0

# Node environment
NODE_ENV=production

# ── Database ─────────────────────────────────────────────────
# Path to SQLite database. Default: ~/.attesting/attesting.db
# Override to place the database on a specific volume or mount.
# ATTESTING_DB_PATH=/var/data/attesting/attesting.db

# ── Organization ─────────────────────────────────────────────
# Your organization name — displayed in the UI header and exports
ATTESTING_ORG_NAME=

# Short org identifier — used in export filenames and audit logs
ATTESTING_ORG_ID=

# ── Branding (optional) ─────────────────────────────────────
# Path to a custom logo file (PNG/SVG, recommended 200x40px)
# ATTESTING_LOGO_PATH=./config/branding/logo.svg

# Primary brand color (hex, used in UI header)
# ATTESTING_BRAND_COLOR=#1F3864

# ── Connector: Jira ──────────────────────────────────────────
# Jira Server or Cloud base URL (no trailing slash)
# JIRA_BASE_URL=https://jira.example.com

# Jira auth — for Cloud: email + API token; for Server: username + PAT
# JIRA_EMAIL=
# JIRA_API_TOKEN=

# Default JQL filter for the Jira connector
# JIRA_DEFAULT_JQL=project = PTCP AND resolution = Unresolved

# ── Connector: Google Drive ──────────────────────────────────
# Service account JSON key file path (for reading program file structure)
# GDRIVE_SERVICE_ACCOUNT_PATH=./config/connectors/gdrive-service-account.json

# Root folder ID to index
# GDRIVE_ROOT_FOLDER_ID=

# ── Connector: Black Duck ────────────────────────────────────
# Black Duck server URL
# BLACKDUCK_URL=https://blackduck.example.com

# Black Duck API token
# BLACKDUCK_API_TOKEN=

# ── Connector: Confluence ────────────────────────────────────
# Confluence base URL
# CONFLUENCE_BASE_URL=https://confluence.example.com

# Confluence auth (same pattern as Jira)
# CONFLUENCE_EMAIL=
# CONFLUENCE_API_TOKEN=

# ── Connector: Okta ──────────────────────────────────────────
# Okta domain (e.g., dev-12345.okta.com)
# OKTA_DOMAIN=

# Okta API token
# OKTA_API_TOKEN=

# ── Connector: CrowdStrike ───────────────────────────────────
# CROWDSTRIKE_CLIENT_ID=
# CROWDSTRIKE_CLIENT_SECRET=
# CROWDSTRIKE_BASE_URL=https://api.crowdstrike.com

# ── Connector: ServiceNow ────────────────────────────────────
# SERVICENOW_INSTANCE=https://example.service-now.com
# SERVICENOW_USERNAME=
# SERVICENOW_PASSWORD=

# ── Connector: Splunk ────────────────────────────────────────
# SPLUNK_BASE_URL=https://splunk.example.com:8089
# SPLUNK_TOKEN=

# ── Connector: AWS Security Hub ──────────────────────────────
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── Connector: Azure AD ──────────────────────────────────────
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=

# ── Connector: GCP Security Command Center ───────────────────
# GCP_PROJECT_ID=
# GCP_SERVICE_ACCOUNT_PATH=./config/connectors/gcp-service-account.json

# ── Drift Scheduler ──────────────────────────────────────────
# Interval in minutes for automated drift checks (default: 60)
# ATTESTING_DRIFT_INTERVAL=60

# ── Logging ──────────────────────────────────────────────────
# Log level: debug | info | warn | error
ATTESTING_LOG_LEVEL=info

# Path to log file (optional — logs to stdout by default)
# ATTESTING_LOG_FILE=/var/log/attesting/attesting.log
