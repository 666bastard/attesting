# The config/ directory holds credentials, branding, and custom catalogs.
# Only config/README.md is committed (as a template).
config/branding/
config/connectors/
config/catalogs/

# Environment
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Test coverage
coverage/

# Logs
*.log
npm-debug.log*

# Excel temp files
~$*.xlsx
~$*.xlsm
.claude/
