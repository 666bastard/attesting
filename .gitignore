# Dependencies
node_modules/

# Build output
dist/

# Database files — NEVER commit org-specific data
*.db
*.sqlite
*.sqlite3

# Local data — org-specific implementations, evidence, exports
data/local/
data/exports/

# Any file with org-specific content
*nutanix*
*customer*

